rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — open read/write for app functionality
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    match /workers/{workerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.uid == workerId && (
          (
            !('activeBookingId' in resource.data) || 
            resource.data.activeBookingId == null || 
            resource.data.activeBookingId == '' ||
            (resource.data.activeBookingId != null && 
             resource.data.activeBookingId != '' && 
             exists(/databases/$(database)/documents/bookings/$(resource.data.activeBookingId)) &&
             get(/databases/$(database)/documents/bookings/$(resource.data.activeBookingId)).data.status in ['completed', 'cancelled', 'rejected'])
          ) 
          ? true 
          : (
            request.resource.data.available == false && 
            request.resource.data.activeBookingId == resource.data.activeBookingId
          )
        ))
      );
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Bookings — open read/write for all authenticated flows
    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if true;
    }

    // Chats — open read/write
    match /chats/{chatId} {
      allow read: if true;
      allow write: if true;
    }

    // Reviews — open read/write
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }

    // Notifications — open read/write (includes subcollection items)
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if true;
    }
    match /notifications/{notifId}/items/{itemId} {
      allow read: if true;
      allow write: if true;
    }

    // Workers Private — allow read/write for all to accommodate admin bypass login
    match /workers_private/{workerId} {
      allow read, write: if true;
    }

    // Tickets — only the ticket creator or admin can read/write
    match /tickets/{ticketId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
