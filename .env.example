# ============================================================
# ServiConnect Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# --- Firebase Configuration ---
# Get these from: Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# --- Firebase Realtime Database (optional — needed for chat) ---
# Get from: Firebase Console > Realtime Database > Data tab (URL at top)
VITE_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com/

# --- Google Gemini AI API Key ---
# Get from: https://aistudio.google.com/app/apikey
# Used for: Worker skill test questions and AI trust score analysis
VITE_GEMINI_API_KEY=your_gemini_api_key_here
